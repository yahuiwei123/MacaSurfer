// =============================================================================
// MacaSurfer Common Configuration
// =============================================================================
// This is the single source of truth for all pipeline parameter defaults.
// Override via CLI flags (MacaSurfer.sh) or a custom config file (--config_file).
//
// Parameter groups:
//   1. Pipeline Control       6. Species-Specific
//   2. GPU / Resources        7. Software Paths
//   3. BOLD Processing        8. Script Locations
//   4. Enhancement            9. Shared Data / Models
//   5. Registration / Surface 10. Atlas & Template Files
// =============================================================================

params {

    // ==========================================================================
    // 1. PIPELINE CONTROL — required inputs, execution mode, stage selection
    // ==========================================================================
    bids_dir          = ""         // BIDS-format input directory (required)
    participant_label = ""         // subject ID(s), comma-separated (required)
    session_id        = ""         // session ID(s), comma-separated (optional)
    out_dir           = ""         // output root directory (required)

    process_stage = "all"          // stage filter: "all", "prepare", "enhance",
                                   //   "surface", "resample", "bold",
                                   //   "biasfield", "detect_vessel", "fake_t2",
                                   //   "acpc_isotropy", "fix_wm", "tessel",
                                   //   "white", "pial"
    before_check = "false"         // run BIDS→YAML config generation only
    after_check  = "false"         // skip config init, run from existing QC dir
    anat_only    = "false"         // skip BOLD pipeline (structural only)
    bold_only    = "false"         // skip structural pipeline (BOLD only)
    debug        = "false"         // print full params map before execution

    // ==========================================================================
    // 2. GPU / RESOURCES
    // ==========================================================================
    gpus    = null                 // comma-separated GPU indices; null = auto-detect
    per_gpu = null                 // concurrency per GPU (null → 1)
    device  = "gpu"                // "gpu" or "cpu" for template registration

    // ==========================================================================
    // 3. BOLD PROCESSING — fMRI-specific parameters
    // ==========================================================================
    bold_task_type    = ""         // BOLD task name filter (empty = all tasks)
    bold_skip_frame   = 0          // frames to discard from start of each run
    bold_bandpass     = "0.01-0.08" // bandpass filter range (Hz), low-high
    bold_sdc          = "true"     // susceptibility distortion correction
    bold_reg_method   = "flirt"    // registration method for BOLD→T1w
    bold_confounds    = "true"     // compute confound regressor time-series
    bold_cifti        = "false"    // generate CIFTI dense timeseries outputs
    bold_volume_space = "MEBRAIN"  // template space for normalized volume output

    // ==========================================================================
    // 4. ENHANCEMENT — anatomical preprocessing settings
    // ==========================================================================
    seg_tool       = "macabrainnet" // tissue segmentation: "macabrainnet" | "nbest"
    bfc_method     = "gauss"        // bias-field correction: "gauss" | "rbf" | "n4" | "sqrt" | "none"
                                    //   ("tgbfc" also accepted, aliased to "gauss")
    fix_white      = "false"        // enable white matter topology fix
    vessel_detect  = "false"        // enable vessel/artery detection
    deep_white     = "false"        // enable deep white surface reconstruction
    t2_refine_pial = "true"         // use T2w to refine pial surface (if available)

    // QC & algorithmic tuning (rarely changed)
    qc_grid_rows         = 6       // QC mosaic rows
    qc_grid_cols         = 6       // QC mosaic columns
    denoise_rician_rad   = 2       // DenoiseImage radial window size
    tessellation_cores   = 8       // CPU cores for surface tessellation

    // ==========================================================================
    // 5. REGISTRATION / SURFACE
    // ==========================================================================
    reg_name = "MSMSulc"           // surface registration name
    omp_num_threads                      = 128  // OpenMP threads for ANTs & Co.
    itk_global_default_number_of_threads = 128  // ITK thread limit

    // ==========================================================================
    // 6. SPECIES-SPECIFIC — template selection depends on species
    //    Supported: "Macaque" | "Human" | "Marmoset"
    // ==========================================================================
    species = "Macaque"
    brain_size                 = "60"
    high_res_mesh              = "164"
    low_res_mesh               = "32@10"
    final_fmri_resolution      = "1.25"
    smoothing_fwhm             = "1.25"
    grayordinates_resolution   = "1.25"
    myelin_mapping_fwhm        = "2"
    surface_smoothing_fwhm     = "2"
    correction_sigma           = "5"

    // ==========================================================================
    // 7. SOFTWARE PATHS — external tool locations
    // ==========================================================================
    freesurfer_home   = "/home/weiyahui/software/freesurfer-7.3.2"
    fsl_dir           = "/home/weiyahui/software/fsl"
    niftyreg_install  = "/home/weiyahui/software/niftyreg"
    antspath          = "/home/weiyahui/software/ants-2.6.5/bin"
    python_env        = "/home/weiyahui/software/miniconda3/envs/macapipe"
    python_inter      = "/home/weiyahui/software/miniconda3/envs/macapipe/bin/python"
    hcppipedir        = "/home/weiyahui/projects/monkey/macasurfer_v3.0/MacaSurfer"
    caret7dir         = "/home/weiyahui/software/workbench/bin_linux64"
    msmbindir         = "/home/weiyahui/software/msm/msm_ubuntu_v3"
    fixdir            = "/home/weiyahui/software/fix"
    fs_license_file   = ""         // FreeSurfer license; auto-detected if empty

    // ==========================================================================
    // 8. SCRIPT LOCATIONS — pipeline stage scripts
    // ==========================================================================
    prepare_script_dir  = "${params.hcppipedir}/nextflow/Prepare"
    enhance_script_dir  = "${params.hcppipedir}/nextflow/Enhance"
    surface_script_dir  = "${params.hcppipedir}/nextflow/Surface"
    resample_script_dir = "${params.hcppipedir}/nextflow/Resample"

    // ==========================================================================
    // 9. SHARED DATA / MODELS — deep-learning models and utility scripts
    // ==========================================================================
    shared_dir        = "${params.hcppipedir}/shared"
    maca_brainnet_dir = "/home/weiyahui/projects/monkey/macaBrainNet_v2"
    maca_unet_path    = "${params.shared_dir}/brainextractor/macaUNet"
    nbest_model_path  = "${params.shared_dir}/tissueextractor"
    utils_path        = "${params.shared_dir}/utils"
    surf_reg_dir      = "${params.shared_dir}/surf_fireants"
    msmconfigdir      = "${params.hcppipedir}/MSMConfig"
    norm_model_path   = "${params.hcppipedir}/global/normative_model/blr"

    // ==========================================================================
    // 10. ATLAS & TEMPLATE FILES
    // ==========================================================================
    // Base directories
    hcppipedir_templates = "${params.hcppipedir}/global/templates"
    hcppipedir_bin       = "${params.hcppipedir}/global/binaries"
    hcppipedir_config    = "${params.hcppipedir}/global/config"

    // Atlases
    atlases_dir      = "${params.hcppipedir_templates}/Atlas_fsaverage_32k"
    cortical_atlases = "MBNA124 Modalities M129 M132"

    // T1w templates (MEBRAIN — Macaque)
    t1w_template       = "${params.hcppipedir_templates}/MEBRAIN/mebrain_T1w_04mm_LIA.nii.gz"
    t1w_template_brain = "${params.hcppipedir_templates}/MEBRAIN/mebrain_T1w_04mm_brain_LIA.nii.gz"
    t1w_template_atlas = "${params.hcppipedir_templates}/MEBRAIN/gca_04mm_LIA.nii.gz"
    t1w_template_2mm   = "${params.hcppipedir_templates}/MEBRAIN/mebrain_T1w_1mm_brain_LIA.nii.gz"
    template_mask      = "${params.hcppipedir_templates}/MEBRAIN/mebrain_T1w_04mm_brainmask_LIA.nii.gz"
    template_2mm_mask  = "${params.hcppipedir_templates}/MEBRAIN/mebrain_T1w_1mm_brainmask_LIA.nii.gz"
    gca_dir            = "${params.hcppipedir_templates}/MEBRAIN/"

    // Tissue priors
    wm_compliment1 = "${params.hcppipedir_templates}/MEBRAIN/wm_04mm_compliment1_LIA.nii.gz"
    wm_compliment2 = "${params.hcppipedir_templates}/MEBRAIN/wm_04mm_compliment2_LIA.nii.gz"
    gm_compliment  = "${params.hcppipedir_templates}/MEBRAIN/gm_04mm_compliment_LIA.nii.gz"

    // Surface atlases
    surface_atlas_dir        = "${params.hcppipedir_templates}/standard_mesh_atlases_macaque_mbna"
    grayordinates_space_dir  = "${params.surface_atlas_dir}"
    reference_myelin_maps    = "${params.surface_atlas_dir}/MacaqueYerkes19.MyelinMap_BC.164k_fs_LR.dscalar.nii"

    // Transforms & configs
    fake_talairch_transform   = "${params.hcppipedir_templates}/MEBRAIN/talairach.fake.xfm"
    rescale_volume_transform  = "${params.hcppipedir_templates}/fs_xfms/Macaque_rescale"
    fnirt_config              = "${params.hcppipedir_config}/T1_2_MNI_NHP.cnf"
    freesurfer_labels         = "${params.hcppipedir_config}/FreeSurferAllLut.txt"

}

// =============================================================================
// Environment configuration for processes
// =============================================================================
env {
    LD_LIBRARY_PATH = "/home/weiyahui/software/fsl/lib:/home/weiyahui/software/freesurfer-7.3.2/lib:\$LD_LIBRARY_PATH"
    FREESURFER_HOME = "${params.freesurfer_home}"
    FSLDIR          = "${params.fsl_dir}"
    FSLOUTPUTTYPE   = "NIFTI_GZ"
    PATH            = "/home/weiyahui/software/afni:/home/weiyahui/software/fsl/bin:/home/weiyahui/software/ants-2.6.5/bin:\$PATH"
    NIFTYREG_INSTALL = "${params.niftyreg_install}"
    ANTSPATH         = "${params.antspath}"
    PYTHON_ENV       = "${params.python_env}"
    PYTHON_INTER     = "${params.python_inter}"
    HCPPIPEDIR       = "${params.hcppipedir}"
    SHARED_DIR       = "${params.shared_dir}"
    MACA_UNET_PATH   = "${params.maca_unet_path}"
    NBEST_MODEL_PATH = "${params.nbest_model_path}"
    UTILS_PATH       = "${params.utils_path}"
    OMP_NUM_THREADS  = "${params.omp_num_threads}"
    ITK_GLOBAL_DEFAULT_NUMBER_OF_THREADS = "${params.itk_global_default_number_of_threads}"
    CARET7DIR        = "${params.caret7dir}"
    CLUSTER          = "2.0"
    SPECIES          = "${params.species}"

    // HCP pipeline directories
    HCPPIPEDIR_Templates       = "${params.hcppipedir_templates}"
    HCPPIPEDIR_Bin             = "${params.hcppipedir_bin}"
    HCPPIPEDIR_Config          = "${params.hcppipedir_config}"
    HCPPIPEDIR_PreFS           = "${params.hcppipedir}/PreFreeSurfer/scripts"
    HCPPIPEDIR_FS              = "${params.hcppipedir}/FreeSurfer/scripts"
    HCPPIPEDIR_PostFS          = "${params.hcppipedir}/PostFreeSurfer/scripts"
    HCPPIPEDIR_Shared          = "${params.shared_dir}"
    HCPPIPEDIR_fMRISurf        = "${params.hcppipedir}/fMRISurface/scripts"
    HCPPIPEDIR_fMRIVol         = "${params.hcppipedir}/fMRIVolume/scripts"
    HCPPIPEDIR_tfMRI           = "${params.hcppipedir}/tfMRI/scripts"
    HCPPIPEDIR_dMRI            = "${params.hcppipedir}/DiffusionPreprocessing/scripts"
    HCPPIPEDIR_dMRITract       = "${params.hcppipedir}/DiffusionTractography"
    HCPPIPEDIR_Global          = "${params.hcppipedir}/global/scripts"
    HCPPIPEDIR_tfMRIAnalysis   = "${params.hcppipedir}/TaskfMRIAnalysis/scripts"

    // Species-specific
    FreeSurferLabels         = "${params.freesurfer_labels}"
    MSMBINDIR                = "${params.msmbindir}"
    MSMCONFIGDIR             = "${params.msmconfigdir}"
    FixDir                   = "${params.fixdir}"
    RegName                  = "${params.reg_name}"
    BrainSize                = "${params.brain_size}"
    T1wTemplate              = "${params.t1w_template}"
    T1wTemplateBrain         = "${params.t1w_template_brain}"
    T1wTemplateAtlas         = "${params.t1w_template_atlas}"
    T1wTemplate2mm           = "${params.t1w_template_2mm}"
    TemplateMask             = "${params.template_mask}"
    Template2mmMask          = "${params.template_2mm_mask}"
    GCAdir                   = "${params.gca_dir}"
    WMCompliment1            = "${params.wm_compliment1}"
    WMCompliment2            = "${params.wm_compliment2}"
    GMCompliment             = "${params.gm_compliment}"
    FakeTalairchTransform    = "${params.fake_talairch_transform}"
    RescaleVolumeTransform   = "${params.rescale_volume_transform}"
    FNIRTConfig              = "${params.fnirt_config}"
    SurfaceAtlasDIR          = "${params.surface_atlas_dir}"
    GrayordinatesSpaceDIR    = "${params.grayordinates_space_dir}"
    ReferenceMyelinMaps      = "${params.reference_myelin_maps}"
    HighResMesh              = "${params.high_res_mesh}"
    LowResMesh               = "${params.low_res_mesh}"
    FinalfMRIResolution      = "${params.final_fmri_resolution}"
    SmoothingFWHM            = "${params.smoothing_fwhm}"
    GrayordinatesResolution  = "${params.grayordinates_resolution}"
    MyelinMappingFWHM        = "${params.myelin_mapping_fwhm}"
    SurfaceSmoothingFWHM     = "${params.surface_smoothing_fwhm}"
    CorrectionSigma          = "${params.correction_sigma}"
}

executor {
    name = 'local'
    // cpus   = 54       // set (CPUs_real * 1.5)
    // memory = '54 GB'  // set (RAM + Swap space - 10) GB
}

process {
    // errorStrategy = 'ignore'
    executor = 'local'

    withLabel: maxForks_10 { maxForks = 10 }
    withLabel: maxForks_2  { maxForks = 2  }
    withLabel: maxForks_1  { maxForks = 1  }
    withLabel: with_gpu    { maxForks = 2  }
}

dag.overwrite      = true
timeline.overwrite = true
report.overwrite   = true
